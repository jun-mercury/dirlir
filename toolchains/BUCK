load("@prelude//toolchains:genrule.bzl", "system_genrule_toolchain")
load("@prelude//toolchains:python.bzl", "python_bootstrap_toolchain")
load("@root//dirlir:lock_util.bzl", "parse_spec", "store_base")
load(":nix_cxx.bzl", "nix_cxx_toolchain")
load(":nix_haskell.bzl", "nix_haskell_toolchain")

system_genrule_toolchain(
    name = "genrule",
    visibility = ["PUBLIC"],
)

# Prelude-internal helper scripts (dep file processing, comp DBs, ...) run
# under this interpreter: the nix python layer via the shim -- NOT a system
# python (this host has none on PATH, and RE workers have none at all).
python_bootstrap_toolchain(
    name = "python_bootstrap",
    interpreter = "root//layers:python3-tool",
    visibility = ["PUBLIC"],
)

nix_cxx_toolchain(
    name = "cxx",
    bin = parse_spec("gcc") + "/bin",
    layer = "root//layers:cxx-toolchain",
    visibility = ["PUBLIC"],
)

nix_haskell_toolchain(
    name = "haskell",
    bin = parse_spec("ghc") + "/bin",
    # "<h>-ghc-9.10.3" -> "9"
    compiler_major_version = store_base("ghc").split("-")[-1].split(".")[0],
    layer = "root//layers:ghc",
    visibility = ["PUBLIC"],
)
