    name = "python_bootstrap",
    interpreter = "root//layers:python3-tool",
    visibility = ["PUBLIC"],
)

nix_cxx_toolchain(
    name = "cxx",
    layer = "root//layers:cxx-toolchain",
    visibility = ["PUBLIC"],
)
