load("//dirlir:import.bzl", "dir_subpath")
load("//dirlir:lock_util.bzl", "parse_spec", "store_base")

# Excised, dereferenced pieces of the openssl layer for prebuilt_cxx_library,
# addressed by store path (no forest).
dir_subpath(
    name = "include",
    layer = "root//layers:openssl",
    path = "nix/store/" + store_base("openssl.dev") + "/include",
)

dir_subpath(
    name = "libssl.so.3",
    is_dir = False,
    layer = "root//layers:openssl",
    path = "nix/store/" + store_base("openssl.out") + "/lib/libssl.so.3",
)

dir_subpath(
    name = "libcrypto.so.3",
    is_dir = False,
    layer = "root//layers:openssl",
    path = "nix/store/" + store_base("openssl.out") + "/lib/libcrypto.so.3",
)

# Runtime resolution model: binaries get an absolute /nix/store RPATH; at
# run time the openssl layer is mounted there by the shim (on nix hosts the
# real store satisfies it too).
_RPATH_FLAG = "-Wl,-rpath," + parse_spec("openssl.out") + "/lib"

prebuilt_cxx_library(
    name = "crypto",
    exported_linker_flags = [_RPATH_FLAG],
    header_dirs = [":include"],
    shared_lib = ":libcrypto.so.3",
    visibility = ["PUBLIC"],
)

prebuilt_cxx_library(
    name = "ssl",
    exported_deps = [":crypto"],
    exported_linker_flags = [_RPATH_FLAG],
    header_dirs = [":include"],
    shared_lib = ":libssl.so.3",
    visibility = ["PUBLIC"],
)
