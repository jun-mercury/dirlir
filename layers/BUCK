load("//dirlir:defs.bzl", "dir_layer", "nix_closure")
load("//dirlir:features.bzl", "feature")
load("//dirlir:import.bzl", "nix_tool")
load("//dirlir:lock_util.bzl", "store_base")

# The C toolchain: nixpkgs wrapped gcc. Its cc-wrapper carries the bintools
# programs; tools are addressed as /nix/store/<base>/bin/<tool> (no forest).
nix_closure(
    name = "cxx-toolchain",
    packages = ["gcc"],
    visibility = ["PUBLIC"],
)

nix_closure(
    name = "python",
    packages = ["python3"],
    visibility = ["PUBLIC"],
)

nix_tool(
    name = "python3-tool",
    layer = ":python",
    path = "nix/store/" + store_base("python3") + "/bin/python3",
    visibility = ["PUBLIC"],
)

# Backs dir_subpath's in-layer cp (RE workers have no host tools).
nix_closure(
    name = "coreutils",
    packages = ["coreutils"],
    visibility = ["PUBLIC"],
)

nix_closure(
    name = "openssl",
    packages = ["openssl.dev", "openssl.out"],
    visibility = ["PUBLIC"],
)

# The Haskell toolchain: nixpkgs ghc (its closure carries its own wrapped
# gcc/binutils for linking).
nix_closure(
    name = "ghc",
    packages = ["ghc"],
    visibility = ["PUBLIC"],
)

nix_closure(
    name = "hello",
    packages = ["hello"],
    visibility = ["PUBLIC"],
)

# Demo/test layer: coreutils+bash so there are in-layer binaries to prove
# store masking with.
nix_closure(
    name = "demo",
    packages = ["bash", "coreutils", "hello"],
    visibility = ["PUBLIC"],
)

# Tooling for dir_layer assembly actions and audit mode (M6).
nix_closure(
    name = "buildtools",
    packages = ["python3", "coreutils", "strace"],
    visibility = ["PUBLIC"],
)

# parent_layer chaining demo: :app inherits :base, replaces a file (remove
# tombstone + install), and adds dirs. Exercises every feature kind.
dir_layer(
    name = "base",
    features = [
        feature.ensure_dirs_exist(path = "/etc/app"),
        feature.install(src = "app.conf", dst = "/etc/app/app.conf"),
        feature.symlink(link = "/etc/app/conf", target = "/etc/app/app.conf"),
        feature.nix_packages(packages = ["hello"]),
    ],
    visibility = ["PUBLIC"],
)

dir_layer(
    name = "app",
    parent_layer = ":base",
    features = [
        feature.remove(path = "/etc/app/app.conf"),
        feature.install(src = "app2.conf", dst = "/etc/app/app.conf"),
        feature.ensure_dirs_exist(path = "/var/log/app"),
    ],
    visibility = ["PUBLIC"],
)
