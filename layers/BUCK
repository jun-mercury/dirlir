load("//dirlir:defs.bzl", "dir_layer")
load("//dirlir:features.bzl", "feature")
load("//dirlir:import.bzl", "nix_tool")

# The C toolchain: nixpkgs wrapped gcc, exposed as a bin/ forest. The
# cc-wrapper already symlinks the bintools programs (ld, ar, nm, ...) into
# its bin/, so adding binutils separately would only create forest
# collisions -- the wrapped binutils rides along in the closure anyway.
dir_layer(
    name = "cxx-toolchain",
    features = [
        feature.nix_packages(packages = ["gcc"]),
    ],
    visibility = ["PUBLIC"],
)

dir_layer(
    name = "python",
    features = [
        feature.nix_packages(packages = ["python3"]),
    ],
    visibility = ["PUBLIC"],
)

nix_tool(
    name = "python3-tool",
    layer = ":python",
    path = "bin/python3",
    visibility = ["PUBLIC"],
)

dir_layer(
    name = "openssl",
    features = [
        feature.nix_packages(
            packages = ["openssl.dev", "openssl.out"],
            forest = ["include", "lib"],
        ),
    ],
    visibility = ["PUBLIC"],
)

dir_layer(
    name = "hello",
    features = [
        feature.nix_packages(packages = ["hello"]),
    ],
    visibility = ["PUBLIC"],
)

# parent_layer chaining demo: :app inherits :base, replaces a file (remove
# tombstone + install), and adds dirs. Exercises every feature kind.
dir_layer(
    name = "base",
    features = [
        feature.ensure_dirs_exist(path = "/etc/app"),
        feature.install(src = "app.conf", dst = "/etc/app/app.conf"),
        feature.symlink(link = "/etc/app/conf", target = "/etc/app/app.conf"),
        feature.nix_packages(packages = ["hello"]),
    ],
    visibility = ["PUBLIC"],
)

dir_layer(
    name = "app",
    parent_layer = ":base",
    features = [
        feature.remove(path = "/etc/app/app.conf"),
        feature.install(src = "app2.conf", dst = "/etc/app/app.conf"),
        feature.ensure_dirs_exist(path = "/var/log/app"),
    ],
    visibility = ["PUBLIC"],
)

# Demo/test layer: coreutils+bash so there are in-layer binaries to prove
# store masking with (on NixOS every host binary needs /nix/store, so host
# tools cannot be used inside the shim's namespace).
dir_layer(
    name = "demo",
    features = [
        feature.nix_packages(packages = ["bash", "coreutils", "hello"]),
    ],
    visibility = ["PUBLIC"],
)
